[Unit]
Description=PeerMarket Slack bridge (socket mode)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=peermarket-agent
Group=peermarket-agent
WorkingDirectory=/opt/peermarket-agent
EnvironmentFile=/etc/peermarket-agent/secrets.env
ExecStart=/opt/peermarket-agent/.venv/bin/peermarket-slack-bridge
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/peermarket-agent
PrivateTmp=true
ProtectHome=true

[Install]
WantedBy=multi-user.target
