# Copy to /etc/peermarket-agent/secrets.env and set real values.
ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_FOUNDER_USER_ID=

# Per-platform report channels (optional; empty = founder DM)
SLACK_REPORT_CHANNEL_TIKTOK=C0BJ71Z4YFL
SLACK_REPORT_CHANNEL_META=C0BJ0PUURRR
SLACK_REPORT_CHANNEL_EMAIL=C0BHRLPM3QX

AGENT_DB_URL=postgresql+asyncpg://peermarket-agent@localhost/peermarket_agent
PEERMARKET_PROD_DB_READONLY_URL=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=/etc/peermarket-agent/github-app.pem
GITHUB_APP_INSTALLATION_ID=
RECRAFT_API_KEY=
RESEND_API_KEY=
BACKBLAZE_B2_KEY_ID=
BACKBLAZE_B2_APP_KEY=
BACKBLAZE_B2_BUCKET=
BACKBLAZE_B2_ENDPOINT=

# Slack video review intake. Keep VIDEO_MEDIA_ROOT below /var/peermarket-agent.
VIDEO_MEDIA_ROOT=/var/peermarket-agent/video-media
VIDEO_RETENTION_DAYS=30
VIDEO_MAX_FILE_BYTES=209715200
VIDEO_MAX_CLIPS=8
VIDEO_MAX_DURATION_SECONDS=60
HEALTHCHECK_PORT=8090
